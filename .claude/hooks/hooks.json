{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scripts/session-start.js"
          }
        ],
        "description": "Load previous session context and detect project type"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scripts/suggest-compact.js"
          }
        ],
        "description": "Suggest manual compaction at logical intervals"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scripts/pre-compact.js"
          }
        ],
        "description": "Save state before context compaction"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scripts/session-end.js",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Persist session state after each response"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scripts/post-merge-reminder.js",
            "async": true,
            "timeout": 5
          }
        ],
        "description": "Remind about /update-docs and retrospective after merge on main"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scripts/compliance-monitor.js",
            "async": true,
            "timeout": 15
          }
        ],
        "description": "Log VKF compliance checks to sessions/compliance-log.jsonl"
      }
    ]
  }
}
