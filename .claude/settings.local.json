{
  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(for dir:*)",
      "Bash(do touch:*)",
      "Bash(done)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(find .claude -name \".gitkeep\" -delete)",
      "Bash(git mv:*)",
      "mcp__github__search_repositories",
      "Bash(claude mcp:*)",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/pre-compact.js''\\)\")",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/suggest-compact.js''\\)\")",
      "mcp__supabase__list_projects",
      "mcp__supabase__get_project",
      "mcp__supabase__list_tables",
      "mcp__supabase__get_table",
      "mcp__supabase__execute_sql",
      "mcp__supabase__list_extensions",
      "mcp__supabase__list_migrations",
      "mcp__supabase__apply_migration",
      "mcp__supabase__get_logs",
      "mcp__supabase__get_project_url",
      "mcp__supabase__get_anon_key",
      "mcp__supabase__generate_typescript_types",
      "mcp__supabase__create_project",
      "mcp__supabase__get_cost",
      "mcp__supabase__confirm_cost",
      "mcp__supabase__list_organizations",
      "mcp__supabase__create_branch",
      "mcp__supabase__list_branches",
      "mcp__supabase__delete_branch",
      "mcp__supabase__reset_branch",
      "mcp__supabase__rebase_branch",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/session-start.js''\\)\")",
      "Bash(node -e \"require\\(''./.claude/hooks/scripts/session-end.js''\\)\")"
    ]
  }
}
